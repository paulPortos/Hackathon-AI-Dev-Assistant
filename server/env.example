# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
# Set DJANGO_DEBUG=False and DJANGO_ALLOWED_HOSTS to real domains in production.
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=UTC
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL
DATABASE_URL=
DATABASE_CONN_MAX_AGE=600
DATABASE_SSL_MODE=
DATABASE_SSL_REQUIRE=False
DB_NAME=hackathon_ai_dev_assistant
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Channels / Redis
REDIS_URL=

# GitHub OAuth / GitHub App
GITHUB_APP_ID=
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:8000/auth/github/callback/
GITHUB_PRIVATE_KEY_PATH=
GITHUB_TOKEN_ENCRYPTION_KEY=replace-with-fernet-key

# Twilio SendGrid
TWILLIO_SENDGRID_API_KEY=
TWILLIO_SENDGRID_FROM_EMAIL=noreply@example.com
TWILLIO_SENDGRID_FROM_NAME=AI Dev Assistant

# Agents / Ollama Cloud
OLLAMA_API_KEY=replace-with-ollama-api-key
OLLAMA_HOST=
OLLAMA_AGENT_MAX_ATTEMPTS=3
OLLAMA_AGENT_RETRY_DELAY_SECONDS=0.75
SR_DEV_AGENT_MODEL=gpt-oss:20b
SR_DEV_TOOL_CALL_LIMIT=8
PROJECT_MANAGER_AGENT_MODEL=gpt-oss:20b
PROJECT_MANAGER_CONFIDENCE_THRESHOLD=75

# JWT
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7

# Security audit logging
SECURITY_AUDIT_LOG_LEVEL=INFO
SECURITY_AUDIT_BODY_MAX_BYTES=8192
SECURITY_AUDIT_MAX_SUSPICIOUS_SIGNALS=20
